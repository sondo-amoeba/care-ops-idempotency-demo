{
  "name": "@care-ops/api",
  "version": "1.0.0",
  "description": "NestJS API — replay-safe SMS invariants for the Care-Ops SMS Invariant Lab",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migration:run": "nest build && node ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:revert": "node ./node_modules/typeorm/cli.js migration:revert -d dist/database/data-source.js"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.3",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.2",
    "@google/generative-ai": "^0.24.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5",
    "@types/express": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.0.0",
    "vitest": "^3.0.5"
  }
}
