# Local development (docker compose postgres + redis)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=careops
POSTGRES_PASSWORD=careops
POSTGRES_DB=careops_demo
REDIS_URL=redis://localhost:6380
API_PORT=3001

# Outbox relay (ADR-0006). Autodrain runs a background poll loop; leave it OFF
# for the interactive demo so the "Drain outbox relay" button is meaningful.
# Always disabled under tests (VITEST / NODE_ENV=test).
OUTBOX_RELAY_AUTODRAIN=false
# RELAY_POLL_MS=500            # autodrain poll interval
# RELAY_REAP_AFTER_MS=30000    # re-queue rows stranded in `submitting` past this
# RELAY_MAX_ATTEMPTS=5         # retries before dead_letter
# RELAY_BACKOFF_BASE_MS=1000   # exponential backoff base (0 = retry immediately)
# CARRIER_MPS=10               # carrier messages-per-second token bucket

# Test / dev — relay carrier-submit simulation (the relay is the sole carrier caller)
# SMS_SIMULATE_SUBMISSION_FAILURE=true
# SMS_SIMULATE_FAILURE_MODE=retryable   # retryable (backoff) | terminal (dead_letter)
# SMS_SIMULATE_CRASH_DURING_SUBMIT=true # strand the row in `submitting` for the reaper

# Web — Next.js rewrites proxy API calls (see apps/web/next.config.mjs)
API_PROXY_URL=http://localhost:3001

# Production (Render API + Vercel web)
# DATABASE_URL=postgres://...          # Neon free — API on Render only
# REDIS_URL=rediss://...               # Upstash free — API on Render only
# API_PROXY_URL=https://care-ops-api.onrender.com   # Vercel env — web only
