# Local development (docker compose postgres + redis)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=careops
POSTGRES_PASSWORD=careops
POSTGRES_DB=careops_demo
REDIS_URL=redis://localhost:6380
API_PORT=3001

# Web — Next.js rewrites proxy API calls (see apps/web/next.config.mjs)
API_PROXY_URL=http://localhost:3001

# Production (Railway / Render API + Vercel web)
# DATABASE_URL=postgres://...          # Neon / Vercel Postgres — API only
# POSTGRES_SSL=false                   # set if provider does not require SSL
# REDIS_URL=rediss://...               # Upstash Redis — API only
# API_PROXY_URL=https://your-api.up.railway.app   # Vercel env — web only
