# Local development (docker compose postgres + redis)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=careops
POSTGRES_PASSWORD=careops
POSTGRES_DB=careops_demo
REDIS_URL=redis://localhost:6380
API_PORT=3001

# Test / dev — force carrier submission failure after ledger claim
# SMS_SIMULATE_SUBMISSION_FAILURE=true

# Web — Next.js rewrites proxy API calls (see apps/web/next.config.mjs)
API_PROXY_URL=http://localhost:3001

# Production (Render API + Vercel web)
# DATABASE_URL=postgres://...          # Neon free — API on Render only
# REDIS_URL=rediss://...               # Upstash free — API on Render only
# API_PROXY_URL=https://care-ops-api.onrender.com   # Vercel env — web only
